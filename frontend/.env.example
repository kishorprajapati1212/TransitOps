# Frontend build-time configuration (baked into the bundle at build time).
#
# VITE_API_URL is the BASE PATH the browser uses for API calls.
# Default "/api" is relative and works in both dev (Vite proxy) and Docker (Nginx proxy).
# For a custom/external backend, set the full origin, e.g.:
#   VITE_API_URL=https://api.transitops.example.com/api
VITE_API_URL=/api

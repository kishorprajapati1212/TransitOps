# ============================================================
# TransitOps - Environment Configuration (copy to .env)
# ============================================================

# Neon PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
# In Project IDX / Neon, copy the "Connection string" -> "pooled" or "URI" value.
DATABASE_URL=postgres://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Server
PORT=4000
NODE_ENV=development

# JSON Web Token
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Optional: log every SQL query to the console (true/false)
SQL_LOG=false

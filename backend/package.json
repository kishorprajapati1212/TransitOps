{
  "name": "transitops-backend",
  "version": "1.0.0",
  "description": "TransitOps - Smart Transport Operations Platform API (Node + Express + PostgreSQL/Neon)",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node migrations/run.js",
    "db:seed": "node migrations/seeder.js",
    "db:reset": "node migrations/run.js && node migrations/seeder.js"
  },
  "keywords": [
    "transitops",
    "transport",
    "fleet",
    "logistics",
    "express",
    "postgres",
    "neon"
  ],
  "author": "Hackathon Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "pg-mem": "^3.0.14"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
